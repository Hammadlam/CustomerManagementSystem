
@{
    ViewData["Title"] = "SuperAdmin";
}


<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">
    <h2>Super Admin Dashboard</h2>

    <!-- Assign Role & userId will be a disable field id will fill according to the selected user automatically-->
    <div class="row mb-3">
        <div class="col-md-3">
            <input type="number" id="userId" class="form-control" placeholder="User ID" />
        </div>
        <!--Select Employee-->
        <div class="col-md-3">
            <select id="roleSelect" class="form-control"></select>
        </div>
        <!--Select User role--> 
        <div class="col-md-3">
            <select id="roleSelect" class="form-control"></select>
        </div>
        <div class="col-md-3">
            <button class="btn btn-primary" onclick="assignRole()">Assign Role</button>
        </div>
    </div>

    <!-- Table -->
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>User</th>
                <th>Designation</th>
                <th>Email</th>
                <th>Roles</th>
                <th>Edit</th>
            </tr>
        </thead>
        <tbody id="userTable"></tbody>
    </table>
</div>
<script src="~/js/ui_js/superadmin.js"></script>
